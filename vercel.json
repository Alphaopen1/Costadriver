{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "fr.costadriver.fr"
        }
      ],
      "destination": "/fr/:path*"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.costadriver.fr"
        }
      ],
      "destination": "/:1"
    },
    {
      "source": "/:path((?!assets|destinations|services|news|fr|favicon|robots|404|_next|\.well-known).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fr/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
